   "source": [
    "#Practice 2 - sun of numbers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "5a286750",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total Sum: 125250\n"
     ]
    }
   ],
   "source": [
    "n = int(input(\"Enter  a number: \"))\n",
    "total = 0 \n",
    "for i in range(1, n+1):\n",
    "    total += i\n",
    "print(f\"Total Sum: {total}\")\n",
    "\n"
   ]
  }
